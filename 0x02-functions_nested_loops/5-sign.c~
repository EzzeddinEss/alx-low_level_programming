#include "main.h"
/**
 * print_sign - check if the number is equal to 1 or 0 or -1.
 *
 * Return: 1 if Greater than Zero.
 * 0 if equal Zero.
 * -1 if less than Zero
 *
 * @n: is the checking parameter
*/

int print_sign(int n)
{
	if (n > 0)
	{
		_putchar ('+');
		return (1);
	}
	else if (n == 0)
	{
		_putchar ('0');
		return (0);
	}
	else
	{
		_putchar('-');
		return(-1);
			
}
